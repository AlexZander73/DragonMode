{
  "name": "dragon-mode-mobile",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "mobile:build": "vite build --config vite.mobile.config.ts",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit",
    "test:domain": "node --import tsx --test tests/domain.test.ts tests/import-fixtures.test.ts",
    "test:rendered": "node --test tests/rendered-html.test.mjs",
    "test:contracts": "node --test tests/release-contract.test.mjs",
    "test": "npm run test:domain && npm run build && npm run test:rendered && npm run test:contracts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern mobile-dist --ignore-pattern artifacts --ignore-pattern ios/App/App/public --ignore-pattern .next",
    "appstore:preflight": "node scripts/app-store-preflight.mjs",
    "ios:build": "bash scripts/ios-build.sh",
    "simulator:certify": "bash scripts/simulator-certify.sh",
    "screenshots:capture": "bash scripts/capture-app-store-screenshot.sh",
    "release:verify": "node scripts/release-verify.mjs",
    "db:generate": "drizzle-kit generate",
    "cap:sync": "npm run mobile:build && cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/splash-screen": "^8.0.2",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.468.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
